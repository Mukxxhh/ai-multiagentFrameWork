# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Alternative models you can use:
# OLLAMA_MODEL=mistral
# OLLAMA_MODEL=codellama
# OLLAMA_MODEL=llama2
# OLLAMA_MODEL=gemma

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# File Upload Settings
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=csv,xlsx,xls,json,pdf,txt,doc,docx,xml,parquet

# Output Settings
OUTPUT_DIR=./output
UPLOAD_DIR=./uploads
